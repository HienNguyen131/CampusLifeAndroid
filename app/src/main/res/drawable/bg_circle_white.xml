<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- Nền trắng -->
    <solid android:color="@android:color/white"/>

    <!-- Bóng đổ nhẹ để icon nổi bật -->
    <size
        android:width="44dp"
        android:height="44dp" />

    <corners android:radius="50dp" />

    <padding
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp"/>

    <!-- Shadow trên API < 28 (giả lập) -->
    <stroke
        android:width="1dp"
        android:color="#1A000000"/>
</shape>
