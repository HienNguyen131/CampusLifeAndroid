<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="RoundedImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    <style name="ProfileRowCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeColor">#11000000</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>
    <style name="Chip.Pill.Orange" parent="Widget.Material3.Chip.Assist.Elevated">
        <item name="android:textColor">@android:color/white</item>
        <item name="chipBackgroundColor">#FF7A00</item>
        <item name="rippleColor">#33FFFFFF</item>
        <item name="chipMinHeight">40dp</item>
        <item name="chipIconTint">@null</item>
        <item name="shapeAppearance">
            @style/ShapeAppearance.Material3.Corner.Full
        </item>
    </style>
    <style name="TopRounded16">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
    <style name="Round12">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    <style name="Button.Filled.Dark" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/black</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="cornerRadius">14dp</item>
        <item name="rippleColor">#33FFFFFF</item>
    </style>
    <style name="Widget.Campus.BottomBar" parent="Widget.Material3.BottomNavigationView">
        <!-- nền bo tròn + đổ bóng -->
        <item name="android:background">@drawable/bg_bottom_nav_rounded_menu</item>
        <item name="backgroundTint">@null</item>
        <item name="elevation">8dp</item>

        <item name="itemIconTint">@color/bottom_nav_item_selector</item>
        <item name="itemTextColor">@color/bottom_nav_item_selector</item>

        <item name="labelVisibilityMode">labeled</item>
    </style>
    <style name="OrangeSegmentButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/segment_stroke</item>
        <item name="strokeWidth">2dp</item>

        <item name="android:textColor">@color/segment_text</item>

        <item name="backgroundTint">@color/segment_background</item>

        <item name="cornerRadius">20dp</item>

        <item name="itemActiveIndicatorStyle">@null</item>

        <item name="rippleColor">@android:color/transparent</item>

        <item name="android:textAllCaps">false</item>
    </style>






    <style name="RoundedImageStyle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    <style name="WeekdayItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#666666</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="RoundedImage16" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>


    <style name="CheckInBox">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:background">@drawable/checkin_box_bg</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">0dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">#111111</item>
        <item name="android:inputType">textCapCharacters</item>
        <item name="android:maxLength">1</item>
    </style>

    <style name="Widget.Campus.BottomBar.NoIndicator" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@null</item>
        <item name="android:background">@color/white</item>
        <item name="backgroundTint">@null</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="rippleColor">@android:color/transparent</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>
    <style name="QuizOption">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">#333</item>
        <item name="android:buttonTint">@color/primary</item>
        <item name="android:background">@drawable/bg_option_selector</item>
        <item name="android:layout_marginVertical">6dp</item>
    </style>
    <style name="EditTextBold">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#111111</item>
    </style>







</resources>