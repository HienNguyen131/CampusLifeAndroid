<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivCover"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_placeholder_transparent"
            app:shapeAppearanceOverlay="@style/RoundedImage16"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_chipgroup"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            tools:text="MUSIC"
            android:textColor="#991B1B"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/ivCover"
            app:layout_constraintTop_toTopOf="@id/ivCover"/>

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="20 Th10"
            android:textColor="@color/profile_text_dim"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvCategory"
            app:layout_constraintBottom_toBottomOf="@id/tvCategory"/>

        <TextView
            android:id="@+id/tvScoreType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_chipgroup"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            tools:text="ĐIỂM RÈN LUYỆN"
            android:textColor="#001C44"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/tvCategory"
            app:layout_constraintTop_toTopOf="@id/tvCategory"
            app:layout_constraintBottom_toBottomOf="@id/tvCategory"/>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            tools:text="Campus Music Fest 2024"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="@id/tvCategory"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCategory"/>

        <ImageView
            android:id="@+id/icLocation"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_location_gray"
            android:layout_marginTop="6dp"
            app:tint="@color/profile_text_dim"
            app:layout_constraintStart_toStartOf="@id/tvTitle"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"/>

        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            tools:text="Hội trường A1"
            android:textSize="12sp"
            android:textColor="@color/profile_text_dim"
            app:layout_constraintStart_toEndOf="@id/icLocation"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/icLocation"
            app:layout_constraintBottom_toBottomOf="@id/icLocation"/>

        <TextView
            android:id="@+id/tvMetrics"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            tools:text="👥 120  |  🏆 5đ  |  🎫 50 vé"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            app:layout_constraintStart_toStartOf="@id/icLocation"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/icLocation" />

        <!-- Preparation Status Badge -->
        <TextView
            android:id="@+id/tvPrepStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            tools:text="🔧 CHUẨN BỊ"
            android:textColor="#065F46"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_pill_prep_active"
            app:layout_constraintStart_toStartOf="@id/icLocation"
            app:layout_constraintTop_toBottomOf="@id/tvMetrics"/>

        <!-- Event Time Status -->
        <TextView
            android:id="@+id/tvDateStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            tools:text="🟢 Đang diễn ra"
            android:textColor="#059669"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_pill_status"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMetrics"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
