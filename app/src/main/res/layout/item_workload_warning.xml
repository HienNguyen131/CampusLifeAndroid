<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <!-- I will programmatically layout_marginBottom = 12dp or set it in java. Background can be dynamically built/set in code using GradientDrawable -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/tvWarningName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nguyễn Văn A"
            android:textColor="#1a1c1c"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWarningDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="5 tasks currently assigned"
            android:textColor="#594237"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvWarningBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:text="OVERLOADED"
        android:textColor="#93000a"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.1" />
</LinearLayout>
