<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvStudentName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lê Hoàng C • 2.000.000 đ"
            android:textColor="#0F172A"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCategoryTaskInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Task #8001 • Ví: VẬN HÀNH SỰ KIỆN • Người tạo: Thủ quỹ"
            android:textColor="#64748B"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tạo lúc: 00:08:00 1/4/2026"
            android:textColor="#94A3B8"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvAmountInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="1.500.000đ"
            android:textColor="#F76B10"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDebtWarning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Cảnh báo: đang ôm nợ cũ"
            android:textColor="#EA580C"
            android:textSize="12sp"
            android:visibility="gone"/>

        <!-- Actions for REQUESTED -->
        <LinearLayout
            android:id="@+id/layoutRequestedActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:visibility="visible">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRejectFund"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Từ chối"
                android:textColor="#EF4444" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApproveFund"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1.5"
                android:text="Duyệt chi"
                app:backgroundTint="#10B981"
                app:cornerRadius="12dp" />
        </LinearLayout>

        <!-- Actions for HOLDING -->
        <LinearLayout
            android:id="@+id/layoutHoldingActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReturnFund"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Xác nhận Hoàn ứng"
                android:textColor="#6D28D9"
                app:strokeColor="#6D28D9"
                app:cornerRadius="12dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
