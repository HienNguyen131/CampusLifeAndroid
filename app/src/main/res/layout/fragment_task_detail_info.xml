<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Task Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#F3F4F6"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin nhiệm vụ"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tvDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tiêu đề nhiệm vụ"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mô tả nhiệm vụ..."
                    android:textColor="@color/profile_text_dim"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Deadline row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_calendar"
                        app:tint="@color/profile_text_dim"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hạn chót:"
                        android:textColor="@color/profile_text_dim"
                        android:textSize="12sp"
                        android:layout_marginStart="6dp"/>
                    <TextView
                        android:id="@+id/tvDetailDeadline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_dark"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <!-- Allocated amount row (if financial) -->
                <LinearLayout
                    android:id="@+id/rowAllocated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_wallet"
                        app:tint="@color/profile_text_dim"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cấp phát:"
                        android:textColor="@color/profile_text_dim"
                        android:textSize="12sp"
                        android:layout_marginStart="6dp"/>
                    <TextView
                        android:id="@+id/tvDetailAllocated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 VNĐ"
                        android:textColor="@color/success_green"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Members Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#F3F4F6"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thành viên"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvMembers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAcceptTask"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Nhận nhiệm vụ"
            android:textSize="14sp"
            android:visibility="gone"
            app:backgroundTint="@color/success_green"
            app:cornerRadius="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRequestComplete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Yêu cầu hoàn thành"
            android:textSize="14sp"
            android:visibility="gone"
            app:backgroundTint="@color/purple_primary"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
