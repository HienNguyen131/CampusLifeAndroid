<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    tools:context=".activity.CreateEventActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_close"
            app:title="Create Event"
            app:titleCentered="true">
            <TextView
                android:id="@+id/tvSaveDraft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="16dp"
                android:text="Save"
                android:textColor="#D9534F"
                android:textStyle="bold"
                android:textSize="14sp" />
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp">

            <!-- 1. Banner Upload -->
            <FrameLayout
                android:id="@+id/flUploadBanner"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@drawable/bg_dashed_border"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/ivBannerPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/llUploadPrompt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_image"
                        app:tint="#888888" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tải lên Banner sự kiện"
                        android:textColor="#555555"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1920 x 1080 RECOMMENDED"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </FrameLayout>

            <!-- 2. Organizer Area -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BAN TỔ CHỨC (BTC)"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#D9534F"
                android:layout_marginBottom="8dp"/>
            
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="0dp"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxCornerRadiusBottomStart="8dp"
                        app:boxCornerRadiusBottomEnd="8dp"
                        app:boxStrokeWidth="0dp"
                        app:boxStrokeWidthFocused="0dp"
                        app:boxBackgroundColor="#F3F4F6"
                        app:startIconDrawable="@drawable/ic_search"
                        app:hintEnabled="false">
                        
                        <AutoCompleteTextView
                            android:id="@+id/actvOrganizer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Tìm kiếm đơn vị tổ chức..."
                            android:textSize="14sp"
                            android:paddingVertical="12dp"
                            android:background="@null"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/cgOrganizers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 3. Basic Info -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="0dp"
                app:cardCornerRadius="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <View
                            android:layout_width="4dp"
                            android:layout_height="16dp"
                            android:background="#D9534F"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thông tin cơ bản"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000000"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TÊN SỰ KIỆN"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="4dp"/>
                    
                    <EditText
                        android:id="@+id/etEventName"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/bg_squircle_white"
                        android:backgroundTint="#F3F4F6"
                            android:paddingHorizontal="12dp"
                        android:hint="Nhập tên sự kiện"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false"
                        android:layout_marginBottom="12dp"
                        android:weightSum="10">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="5"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LOẠI SỰ KIỆN"
                                android:textSize="10sp"
                                android:textColor="#888888"
                                android:layout_marginBottom="4dp"/>
                            <Spinner
                                android:id="@+id/spinnerEventType"
                                android:layout_width="match_parent"
                                android:layout_height="45dp"
                                android:background="@drawable/bg_squircle_white"
                                android:backgroundTint="#F3F4F6"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="5"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ĐIỂM CỘNG"
                                android:textSize="10sp"
                                android:textColor="#888888"
                                android:layout_marginBottom="4dp"/>
                            <EditText
                                android:id="@+id/etMaxPoints"
                                android:layout_width="match_parent"
                                android:layout_height="45dp"
                                android:background="@drawable/bg_squircle_white"
                                android:backgroundTint="#F3F4F6"
                                android:gravity="center"
                                android:inputType="numberDecimal"
                                android:text="0"
                                android:textSize="14sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MÔ TẢ CHI TIẾT"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="4dp"/>
                    
                    <EditText
                        android:id="@+id/etDescription"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_squircle_white"
                        android:backgroundTint="#F3F4F6"
                        android:gravity="top|start"
                        android:padding="12dp"
                        android:hint="Nhập nội dung sự kiện tại đây..."
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUYỀN LỢI KHI THAM GIA"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="4dp"/>
                    
                    <EditText
                        android:id="@+id/etBenefits"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_squircle_white"
                        android:backgroundTint="#F3F4F6"
                        android:gravity="top|start"
                        android:padding="12dp"
                        android:hint="Lợi ích sinh viên nhận được..."
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YÊU CẦU THAM GIA"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="4dp"/>
                    
                    <EditText
                        android:id="@+id/etRequirements"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_squircle_white"
                        android:backgroundTint="#F3F4F6"
                        android:gravity="top|start"
                        android:padding="12dp"
                        android:hint="Yêu cầu đối với sinh viên..."
                        android:textSize="14sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="0dp"
                app:cardCornerRadius="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <View
                            android:layout_width="4dp"
                            android:layout_height="16dp"
                            android:background="#8B5CF6"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thời gian &amp; Địa điểm"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000000"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false"
                        android:layout_marginBottom="12dp"
                        android:weightSum="10">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="5"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BẮT ĐẦU"
                                android:textSize="10sp"
                                android:textColor="#888888"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tvStartDate"
                                android:layout_width="match_parent"
                                android:layout_height="45dp"
                                android:background="@drawable/bg_squircle_white"
                                android:backgroundTint="#F3F4F6"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="12dp"
                                android:hint="mm/dd/yyyy, --:--"
                                android:textSize="13sp"
                                app:drawableStartCompat="@drawable/ic_calendar_month"
                                android:drawablePadding="8dp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="5"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="KẾT THÚC"
                                android:textSize="10sp"
                                android:textColor="#888888"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tvEndDate"
                                android:layout_width="match_parent"
                                android:layout_height="45dp"
                                android:background="@drawable/bg_squircle_white"
                                android:backgroundTint="#F3F4F6"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="12dp"
                                android:hint="mm/dd/yyyy, --:--"
                                android:textSize="13sp"
                                app:drawableStartCompat="@drawable/ic_calendar_month"
                                android:drawablePadding="8dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HẠN ĐĂNG KÝ"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvRegDeadline"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/bg_squircle_white"
                        android:backgroundTint="#F3F4F6"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:hint="mm/dd/yyyy, --:--"
                        android:textSize="13sp"
                        app:drawableStartCompat="@drawable/ic_person"
                        android:drawablePadding="8dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ĐỊA ĐIỂM TỔ CHỨC"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="4dp"/>
                    <EditText
                        android:id="@+id/etLocation"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/bg_squircle_white"
                        android:backgroundTint="#F3F4F6"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:hint="Tên hội trường, phòng học..."
                        android:textSize="14sp"
                        android:drawableStart="@drawable/ic_location_on"
                        android:drawablePadding="8dp"
                        android:drawableTint="#888888"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LINK CHIA SẺ"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="4dp"/>
                    <EditText
                        android:id="@+id/etShareLink"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/bg_squircle_white"
                        android:backgroundTint="#F3F4F6"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:hint="Link bài viết Facebook, Zalo..."
                        android:inputType="textUri"
                        android:textSize="14sp"
                        android:drawableStart="@drawable/ic_important"
                        android:drawablePadding="8dp"
                        android:drawableTint="#888888"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THÔNG TIN LIÊN HỆ"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="4dp"/>
                    <EditText
                        android:id="@+id/etContactInfo"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/bg_squircle_white"
                        android:backgroundTint="#F3F4F6"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:hint="Email, SĐT liên hệ BTC..."
                        android:inputType="textEmailAddress"
                        android:textSize="14sp"
                        android:drawableStart="@drawable/ic_person"
                        android:drawablePadding="8dp"
                        android:drawableTint="#888888"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 5. Config Area -->
             <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="0dp"
                app:cardCornerRadius="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cấu hình hệ thống"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginBottom="16dp"/>

                    <!-- Item 1: Ticket qty -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_circle_light"
                            android:layout_marginEnd="12dp">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_confirmation_number"
                                app:tint="#888888"/>
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Số lượng vé"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:textSize="13sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tổng số sinh viên có thể tham dự"
                                android:textColor="#888888"
                                android:textSize="11sp"/>
                        </LinearLayout>
                        <EditText
                            android:id="@+id/etTicketQuantity"
                            android:layout_width="60dp"
                            android:layout_height="35dp"
                            android:background="@drawable/bg_squircle_white"
                            android:backgroundTint="#F3F4F6"
                            android:gravity="center"
                            android:inputType="number"
                            android:text="100"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- Item 1.5: Unlimited Tickets -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_circle_light"
                            android:layout_marginEnd="12dp">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                app:tint="#888888"/>
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Không giới hạn vé"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:textSize="13sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bất kỳ ai cũng có thể tham dự"
                                android:textColor="#888888"
                                android:textSize="11sp"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swUnlimitedTickets"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:useMaterialThemeColors="false"
                            app:thumbTint="@color/switch_thumb_color"
                            app:trackTint="@color/switch_track_color"/>
                    </LinearLayout>

                    <!-- Item 2: Requires Submission -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_circle_light"
                            android:layout_marginEnd="12dp">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                app:tint="#888888"/>
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Yêu cầu nộp bài thu hoạch"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:textSize="13sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SV cần nộp bài thu hoạch sau sự kiện"
                                android:textColor="#888888"
                                android:textSize="11sp"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swRequiresSubmission"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:useMaterialThemeColors="false"
                            app:thumbTint="@color/switch_thumb_color"
                            app:trackTint="@color/switch_track_color"
                            android:checked="true"/>
                    </LinearLayout>

                    <!-- Item 3: Requires Approval -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_circle_light"
                            android:layout_marginEnd="12dp">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_shield"
                                app:tint="#888888"/>
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Đăng ký cần duyệt"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:textSize="13sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tắt để tự động duyệt"
                                android:textColor="#888888"
                                android:textSize="11sp"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swRequiresApproval"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:useMaterialThemeColors="false"
                            app:thumbTint="@color/switch_thumb_color"
                            app:trackTint="@color/switch_track_color"/>
                    </LinearLayout>

                    <!-- Item 5: Important Event -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_circle_light"
                            android:layout_marginEnd="12dp">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_important"
                                app:tint="#888888"/>
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sự kiện quan trọng"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:textSize="13sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tự động duyệt, không giới hạn vé"
                                android:textColor="#888888"
                                android:textSize="11sp"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swImportant"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" 
                            app:useMaterialThemeColors="false"
                            app:thumbTint="@color/switch_thumb_color"
                            app:trackTint="@color/switch_track_color"/>
                    </LinearLayout>

                    <!-- Item 4: Mandatory for Faculty -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_circle_light"
                            android:layout_marginEnd="12dp">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_school"
                                app:tint="#888888"/>
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bắt buộc khoa"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:textSize="13sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chỉ dành cho SV khoa chuyên môn"
                                android:textColor="#888888"
                                android:textSize="11sp"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swMandatory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" 
                            app:useMaterialThemeColors="false"
                            app:thumbTint="@color/switch_thumb_color"
                            app:trackTint="@color/switch_track_color"/>
                    </LinearLayout>

                    <!-- Item 6: Save as Draft -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_circle_light"
                            android:layout_marginEnd="12dp">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_edit"
                                app:tint="#888888"/>
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lưu dưới dạng bản nháp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:textSize="13sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chưa công bố sự kiện này ra ngoài"
                                android:textColor="#888888"
                                android:textSize="11sp"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swDraft"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" 
                            app:useMaterialThemeColors="false"
                            app:thumbTint="@color/switch_thumb_color"
                            app:trackTint="@color/switch_track_color"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Button -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:padding="16dp"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateEvent"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="TẠO SỰ KIỆN"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:backgroundTint="#D9534F"
            app:icon="@drawable/ic_add_circle"
            app:iconGravity="textStart"
            android:textColor="@color/white"/>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
